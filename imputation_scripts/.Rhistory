# Optional numeric proxy for TimeSearching (minutes) based on text patterns
# This is intentionally conservative and may return NA if the pattern is unknown.
time_to_minutes <- function(x) {
x <- tolower(trimws(x))
if (is.na(x) || x == "") {
return(NA_real_)
}
if (grepl("less than", x)) {
return(0)
}
if (grepl("more than", x) && grepl("hour", x)) {
return(120)
}
# Try to capture the lower bound of a range (e.g., "15-30 minutes")
nums <- regmatches(x, gregexpr("[0-9]+", x))
if (length(nums) > 0 && length(nums[[1]]) > 0) {
return(as.numeric(nums[[1]][1]))
}
return(NA_real_)
}
